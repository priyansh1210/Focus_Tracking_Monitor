{
  "manifest_version": 3,
  "name": "Student Focus Monitor",
  "version": "1.0.0",
  "description": "Track your study focus patterns — tab switches, idle time, clicks, and more. Self-monitoring tool for better learning habits.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "idle",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
